{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.0"
    },
    "admin/**/*.php": {
      "runtime": "vercel-php@0.7.0"
    },
    "panel/**/*.php": {
      "runtime": "vercel-php@0.7.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "routes": [
    { "src": "/panel/(.*)", "dest": "/panel/$1" },
    { "src": "/admin/(.*)", "dest": "/admin/$1" }
  ]
}
